# SPA fallback for TaskNow (e.g. IONOS Apache)
# When uploading build to IONOS, copy this file into the same folder as index.html (your document root).

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  # Don't rewrite files or directories
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  # Send everything else to index.html for client-side routing
  RewriteRule ^ index.html [L]
</IfModule>

# Optional: force HTTPS (uncomment if your host supports it)
# <IfModule mod_rewrite.c>
#   RewriteCond %{HTTPS} off
#   RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
# </IfModule>
